# =============================================================================
# EventShield Pro - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
API_KEY=your-api-key-for-device-endpoints
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# --- Database ---
# SQLite (development): sqlite+aiosqlite:///./eventshield.db
# PostgreSQL (production): postgresql+asyncpg://user:pass@localhost:5432/eventshield
DATABASE_URL=sqlite+aiosqlite:///./eventshield.db

# --- Square ---
SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXX
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
SQUARE_ENVIRONMENT=sandbox

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567
SMS_ENABLED=true

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=tickets@yourdomain.com
SENDGRID_FROM_NAME=EventShield Pro
EMAIL_ENABLED=true

# --- Network ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOCAL_SERVER_IP=192.168.1.10

# --- F8881 Devices ---
DEVICE_HEALTH_INTERVAL=30
DEVICE_PING_TIMEOUT=3
DEVICE_SYNC_TIMEOUT=5

# --- Cloud Sync ---
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=https://your-cloud-server.com/api/sync
CLOUD_SYNC_INTERVAL=60
CLOUD_SYNC_API_KEY=your-cloud-api-key

# --- Encryption ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
