# ==============================================================================
# EVENTSHIELD PRO - EMAIL & SMS NOTIFICATION CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: For the notification system to work, you MUST configure at least
# ONE of the following services:
#   1. Email-to-SMS (recommended - uses Gmail/SMTP to send SMS)
#   2. Google Voice SMS (requires Google Voice API)
#   3. Google Chat SMS (requires Google Chat webhook)
# ==============================================================================

# ------------------------------------------------------------------------------
# EMAIL-TO-SMS CONFIGURATION (RECOMMENDED - EASIEST TO SETUP)
# ------------------------------------------------------------------------------
# This service uses your email account to send SMS messages via carrier gateways
# For Gmail: You MUST use an "App Password" (not your regular password)
# To create a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already enabled
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select "Mail" and your device, then generate password
#   5. Copy the 16-character password (remove spaces)

# Your email address (Gmail recommended)
SENDER_EMAIL=your-email@gmail.com
# IMPORTANT: Use App Password for Gmail, not your regular password!
SENDER_PASSWORD=your-16-character-app-password

# SMTP Configuration (Gmail defaults - change if using different provider)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Alternative environment variable names (for compatibility)
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ------------------------------------------------------------------------------
# GOOGLE VOICE SMS CONFIGURATION (OPTIONAL - ADVANCED)
# ------------------------------------------------------------------------------
# Requires Google Voice API access and OAuth2 credentials
# Leave blank if not using Google Voice

GOOGLE_VOICE_API_KEY=
GOOGLE_VOICE_NUMBER=

# ------------------------------------------------------------------------------
# GOOGLE CHAT SMS CONFIGURATION (OPTIONAL - ADVANCED)
# ------------------------------------------------------------------------------
# Requires Google Chat webhook URL
# Leave blank if not using Google Chat

GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_CHAT_SPACE_ID=
GOOGLE_CHAT_API_KEY=

# ==============================================================================
# TESTING YOUR CONFIGURATION
# ==============================================================================
# After setting up your credentials:
# 1. Copy this file to .env (without .example)
# 2. Fill in your actual credentials above
# 3. Restart the EventShield Pro backend
# 4. Use the "TEST CARRIER SMS" button in the UI to test
# 5. Check the backend logs for detailed error messages if it fails
# ==============================================================================
