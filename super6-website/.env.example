# Super6 Website Environment Variables
# Copy this to .env.local and fill in real values. Never commit .env.local.

# ---------- Site ----------
# Used for OG images, sitemap, Stripe redirect URLs.
NEXT_PUBLIC_URL=https://www.thesuper6.com

# ---------- Stripe (registration checkout — P0-02 in super6-FULL-audit.md) ----------
# Test keys for development; replace with live keys for production.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (create in Stripe dashboard, then paste). Names match the
# tier strings posted from /register.
STRIPE_PRICE_ID_SINGLE_TOURNAMENT=price_...
STRIPE_PRICE_ID_SEASON_PASS=price_...

# ---------- Registration backing store (P0-02 — pending TK decision) ----------
# Pick ONE of: supabase | airtable | sheets | email
# Leave commented until TK decides where paid registrations land.
# REGISTRATION_BACKING_STORE=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=
# GOOGLE_SHEETS_WEBHOOK_URL=

# ---------- Newsletter (P1-05 — pending TK decision) ----------
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=
# BEEHIIV_API_KEY=
# BEEHIIV_PUBLICATION_ID=

# ---------- SMS list (P1-05 — Twilio, shared with EventShield Pro) ----------
