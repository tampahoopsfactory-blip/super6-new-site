# EventShield Pro — Local environment variables
# Copy to .env.local and fill in real values
# These are loaded by docker-compose and the Flask app

# ── App ──────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=replace-with-random-64-char-string
JWT_SECRET_KEY=replace-with-random-64-char-string

# ── Database (leave blank to use SQLite in standalone mode) ──────────────────
DATABASE_URL=

# ── Redis (leave blank to use in-memory fallback) ────────────────────────────
REDIS_URL=

# ── Stripe (test mode keys from dashboard.stripe.com) ───────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ENTERPRISE=price_...
